# ----------------------------------------------------------------------
# Project Context (schema-enforced)
# ----------------------------------------------------------------------
# Auto-generated by kerby. Fill in the sections below.
#
# Rules:
# - Sections `project`, `runtime`, and `stack` must exist.
# - These sections are primarily maintained by humans.
# - AI agents may freely extend ONLY the `agentNotes` section, and may
#   edit core sections only when explicitly instructed.
# ----------------------------------------------------------------------

version: 1.0.0
lastUpdated: {{ISO_DATE}}

project:
  name: "{{PROJECT_NAME}}"
  description: ""
  type: ""            # e.g. web-app, api, cli, library, browser-extension
  visibility: private

runtime:
  primary: ""         # e.g. bun, node, deno, python
  language: ""        # e.g. typescript, python, go
  target: ""          # e.g. nextjs, nestjs, chrome-extension-v3

stack:
  frameworks: {}
  tools: {}
  # Expand `tools` like this to adopt `kerby code audit --sast` (opt-in). Pins are
  # project-owned — kerby resolves them, never tracks upstream. All network at
  # setup, none at scan. See references/sast-provisioning.md.
  #   tools:
  #     sast:
  #       enabled: true
  #       python: "3.12.7"                            # pinned interpreter
  #       requirements: "sast/requirements.lock"      # COMMITTED hash-locked lockfile (pip --require-hashes) — NOT inside the .kerby/sast cache
  #       semgrep:
  #         version: "1.86.0"
  #         ruleset: "p/owasp-top-ten@<rev>"          # pinned ruleset (OWASP/CWE)
  #       advisoryDb:
  #         snapshot: "osv-2026-06-15"
  #         date: "2026-06-15"                         # -> coverage-banner freshness line
  #       # gitleaks already exists (pre-commit-check.sh) — referenced, never re-pinned
  aiProviders: []

entryPoints: []        # e.g. ["src/main.ts"]
directories:
  source: src/
  public: public/
  distribution: dist/

# Optional: Quick overview for agent orientation (human-maintained, ~20 lines max)
# Uncomment and fill when project structure is established
# projectStructure: |
#   src/
#   ├── components/
#   ├── lib/
#   └── index.ts

ai:
  enabled: false
  usage: []
  notes: []
  memoryPolicy:
    logTo: .kerby/memory.log
    maxEntries: 200
  # Grade (1–7) at/above which a written plan is required before code (default 4 = beyond
  # trivial). Also gates routing: quick-task is reachable only when grade < this value.
  # Lower = more coverage but risks plan-fatigue (a gate that always fires gets skimmed past).
  # Capped at 7: approval is fixed at grade >= 7, so a higher threshold would make grade-7
  # work require approval with no plan to review. 7 means plan and approval coincide.
  planThreshold: 4

# Project knowledge base (.kerby/knowledge/) — managed by the knowledge-bootstrap
# (SessionStart) and knowledge-reindex (post-commit) hooks. Set enabled: false
# to opt out; default is on whenever this section is missing.
knowledge:
  enabled: true

preferences: {}
status:
  editableBy: [human, ai]
  changePolicy: append-log
  lastEditedBy: human

agentNotes: {}
